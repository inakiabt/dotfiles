#!/usr/bin/env bash

# Make sure we’re using the latest Homebrew
brew update

# Upgrade any already-installed formulae
brew upgrade

# Caskroom
brew tap caskroom/cask

# Install GNU core utilities (those that come with OS X are outdated)
brew install coreutils
echo "Don’t forget to add $(brew --prefix coreutils)/libexec/gnubin to \$PATH."
# Install GNU `find`, `locate`, `updatedb`, and `xargs`, g-prefixed
brew install findutils

brew install bash-completion
brew install gettext
brew install gnu-sed
brew install ccat
brew install ngrep
brew install aria2
brew install brew-cask-completion
brew install git
brew install gnu-tar
brew install pinentry-mac
brew install autoenv
brew install coreutils
brew install git-flow
brew install gnupg
brew install nvm
brew install awscli
brew install curl
brew install git-radar
brew install mackup
brew install bash
brew install diff-so-fancy
brew install gpg-agent
brew install wget --enable-iri
brew install michaeldfallen/formula/git-radar
brew install tree
brew install subliminal
brew install sshuttle

function installcask() {
    brew cask install "${@}" 2> /dev/null
}

installcask atom
installcask bartender
installcask bettertouchtool
installcask bitbar
installcask caffeine
installcask diffmerge
installcask jumpcut
installcask spotify
installcask slack
installcask whatsapp
installcask telegram
installcask imageoptim
installcask iterm2
installcask vlc
installcask github-desktop

# Quick Look
installcask suspicious-package
qlmanage -r

# Remove outdated versions from the cellar
brew cleanup
